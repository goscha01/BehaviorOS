# === Django ===
SECRET_KEY=your-secret-key-here
DEBUG=True
# Comma-separated. On Railway, add the *.railway.app host of your service.
ALLOWED_HOSTS=localhost,127.0.0.1

# === Database ===
# Use Railway's Postgres addon URL in prod. Local dev picks up postgres from docker-compose.
DATABASE_URL=postgresql://postgres:password@localhost:5432/behavioros

# === Redis (Celery broker + result backend) ===
REDIS_URL=redis://localhost:6379/0

# === CORS + CSRF (prod) ===
# In prod, set BOTH to a comma-separated list of exact frontend origins
# (schemes required for CSRF_TRUSTED_ORIGINS). Locally, defaults are fine.
FRONTEND_URL=http://localhost:3000
# CORS_ALLOWED_ORIGINS=https://app.behavioros.com,https://behavioros.com
# CSRF_TRUSTED_ORIGINS=https://app.behavioros.com,https://behavioros.com

# === Frontend build ===
NEXT_PUBLIC_API_URL=http://localhost:8000

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx

# === LLM providers ===
# Set this to enable real (non-stub) analysis + synthesis. Absent → StubProvider.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Learning engine ===
# Analysis model runs per evidence (high volume, cheap). Synthesis runs per cluster
# (low volume, high-judgment). Overrides let us swap providers without code changes.
# LEARNING_ANALYSIS_MODEL=claude-haiku-4-5-20251001
# LEARNING_SYNTHESIS_MODEL=claude-opus-4-7
# LEARNING_EMBEDDING_MODEL=voyage-3-lite
# Hard cost ceiling per nightly job. Exceeded → job status=partial; work resumes next run.
# LEARNING_JOB_MAX_USD=5.0
# LEARNING_MIN_SUPPORTING_EVIDENCE=3
# LEARNING_REJECTION_TTL_DAYS=90
# Which source adapters to pull from on scheduled runs (comma-separated).
# LEARNING_ENABLED_SOURCES=leadbridge,callio,serviceflow
# Nightly job schedule (UTC).
# LEARNING_NIGHTLY_HOUR=2
# LEARNING_NIGHTLY_MINUTE=0

# === Evidence source adapter endpoints ===
# Empty → adapter uses bundled fixtures (safe for dev + first deploy).
# Fill these in once LeadBridge / Callio / ServiceFlow expose read-only endpoints.
LEADBRIDGE_LEARNING_URL=
LEADBRIDGE_LEARNING_TOKEN=
CALLIO_LEARNING_URL=
CALLIO_LEARNING_TOKEN=
SERVICEFLOW_LEARNING_URL=
SERVICEFLOW_LEARNING_TOKEN=

# === Context Provider (Phase 1) ===
# Shadow mode by default: providers run + log every request, but the endpoint
# returns `{"status": "no_context"}` regardless. Flip to true in staging/prod
# only after you're satisfied with what the shadow logs show.
# BEHAVIOR_CONTEXT_ENABLED=false
# Shared bearer token that LeadBridge / Callio must present in Authorization.
# Empty = anonymous calls accepted (dev-friendly). Always set in prod.
# BEHAVIOR_CONTEXT_SERVICE_TOKEN=

# === ElevenLabs (training app) ===
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
